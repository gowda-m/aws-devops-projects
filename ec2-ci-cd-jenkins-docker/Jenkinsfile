pipeline {
    agent any

    environment {
        APP_DIR = "${WORKSPACE}/ec2-ci-cd-jenkins-docker"  // path to your repo folder
        IMAGE_NAME = "my-static-site:latest"
        CONTAINER_NAME = "static-site"
    }

    stages {
        stage('Clone Repo') {
            steps {
                echo "Cloning public GitHub repo..."
                git url: 'https://github.com/gowda-m/aws-devops-projects.git', branch: 'main'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "Building Docker image..."
                sh """
                    cd ${APP_DIR}
                    sudo docker build -t ${IMAGE_NAME} .
                """
            }
        }

        stage('Run Docker Container') {
            steps {
                echo "Running Docker container..."
                sh """
                    # Stop and remove previous container if exists
                    sudo docker stop ${CONTAINER_NAME} || true
                    sudo docker rm ${CONTAINER_NAME} || true

                    # Run new container
                    sudo docker run -d -p 80:80 --name ${CONTAINER_NAME} ${IMAGE_NAME}
                """
            }
        }

        stage('Verify Deployment') {
            steps {
                echo "Deployment complete. Check via browser at http://<EC2-Public-IP>"
                sh "sudo docker ps"
            }
        }
    }

    post {
        always {
            echo "Containerized website pipeline finished!"
        }
    }
}
