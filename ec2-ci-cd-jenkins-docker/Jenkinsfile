pipeline {
    agent any
    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/gowda-m/aws-devops-projects.git'
            }
        }
        stage('Deploy') {
            steps {
                sh 'sudo cp ec2-ci-cd-jenkins-docker/index.html /var/www/html/'
            }
        }
    }
}
