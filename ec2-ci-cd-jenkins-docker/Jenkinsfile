pipeline {
    agent any   // uses any available executor, including your online EC2 agent

    stages {
        stage('Hello') {
            steps {
                echo 'Hello from Jenkins!'
            }
        }

        stage('Check Node') {
            steps {
                sh 'whoami'       // prints the user running the job
                sh 'pwd'          // prints current directory
                sh 'ls -l'        // lists files in workspace
            }
        }

        stage('Test Deploy') {
            steps {
                sh '''
                    echo "<h1>CI/CD Test Success</h1>" > index.html
                    sudo cp index.html /var/www/html/
                '''
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished.'
        }
    }
}
