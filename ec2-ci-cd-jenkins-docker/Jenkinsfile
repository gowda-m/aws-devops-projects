pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git credentialsId: 'github-creds', url: 'https://github.com/<username>/repo.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-static-site:latest .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker stop static-site || true'
                sh 'docker rm static-site || true'
                sh 'docker run -d -p 80:80 --name static-site my-static-site:latest'
            }
        }
    }
}
